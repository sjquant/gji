{
  "name": "@solaqua/gji",
  "version": "0.1.0-beta.6",
  "description": "Git worktree CLI for fast context switching.",
  "license": "MIT",
  "author": "sjquant",
  "type": "module",
  "packageManager": "pnpm@10.6.3",
  "homepage": "https://github.com/sjquant/gji#readme",
  "bugs": {
    "url": "https://github.com/sjquant/gji/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sjquant/gji.git"
  },
  "keywords": [
    "git",
    "worktree",
    "cli",
    "developer-tools",
    "productivity",
    "terminal"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "gji": "dist/index.js"
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm test && pnpm build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/core": "0.5.0",
    "@clack/prompts": "^0.11.0",
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
